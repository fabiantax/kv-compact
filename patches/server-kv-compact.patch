KV Cache Compaction — llama-server integration patch
====================================================

This patch adds automatic KV cache compaction to llama-server via two hooks:

1. process_token() [no-context-shift path]:
   When --no-context-shift is used with --kv-compact-ratio, compacts the cache
   instead of stopping generation when context fills up. Re-compacts each time
   the cache fills again, allowing indefinite generation.

2. update_slots() [context-shift path]:
   When --kv-compact-ratio is used WITH context shifting enabled, tries
   compaction first. Falls back to standard context shift if compaction fails.

Both hooks use kept_positions to accurately rebuild the server's token
bookkeeping after compaction (maps original token positions to compacted ones).

Applied automatically by CMake or manually via: bash patches/apply.sh

--- a/tools/server/server-context.cpp
+++ b/tools/server/server-context.cpp
@@ -1,6 +1,8 @@
 #include "server-context.h"
 #include "server-common.h"

+#include "kv-compact-api.h"
+
 #include "common.h"
 #include "llama.h"
 #include "log.h"

=== process_token(): no-context-shift compaction hook ===

Replace the context-full early stop with KV compaction:

-        // if context shifting is disabled, make sure that we don't run out of context
-        if (!params_base.ctx_shift && slot.prompt.n_tokens() + 1 >= slot.n_ctx) {
-            slot.truncated      = true;
-            slot.stop           = STOP_TYPE_LIMIT;
-            slot.has_next_token = false;
-            SLT_DBG(slot, "stopped due to running out of context capacity, ...");
-        }
+        // if context shifting is disabled: try KV compaction if enabled, otherwise stop
+        if (!params_base.ctx_shift && slot.prompt.n_tokens() + 1 >= slot.n_ctx && params_base.kv_compact_ratio <= 0.0f) {
+            // No compaction — stop as before
+        }
+
+        if (!params_base.ctx_shift && params_base.kv_compact_ratio > 0.0f && slot.prompt.n_tokens() + 1 >= slot.n_ctx) {
+            // Allocate kept_positions buffer, call kv_compact_sequence()
+            // On success: rebuild tokens using kept_positions, continue generating
+            // On failure: stop with STOP_TYPE_LIMIT
+        }

=== update_slots(): context-shift compaction hook ===

Replace the context-shift block with try-compaction-first:

-                const int n_left    = slot.prompt.n_tokens() - n_keep;
-                const int n_discard = ...;
-                llama_memory_seq_rm (...);
-                llama_memory_seq_add(...);
-                // rebuild tokens with simple shift
+                // Try KV cache compaction if enabled
+                if (params_base.kv_compact_ratio > 0.0f) {
+                    // call kv_compact_sequence() with kept_positions
+                }
+                if (new_size > 0) {
+                    // rebuild tokens using kept_positions
+                } else {
+                    // fall back to original context shift
+                }

--- a/tools/server/CMakeLists.txt
+++ b/tools/server/CMakeLists.txt
@@ target_link_libraries
 target_link_libraries(${TARGET} PUBLIC common mtmd ${CMAKE_THREAD_LIBS_INIT})

+# KV compaction integration
+if(TARGET kv-compact-lib)
+    target_link_libraries(${TARGET} PUBLIC kv-compact-lib)
+endif()

--- a/common/common.h
+++ b/common/common.h
@@ kv_unified
     bool kv_unified = false;
+
+    float kv_compact_ratio = 0.0f;  // KV compaction ratio (0.0 = disabled, 0.5 = keep 50%, etc.)

--- a/common/arg.cpp
+++ b/common/arg.cpp
@@ LLAMA_ARG_CONTEXT_SHIFT
+    add_opt(common_arg(
+        {"--kv-compact-ratio"}, "N",
+        "KV cache compaction ratio when context is full (0.0 = disabled, 0.5 = keep 50%)",
+        [](common_params & params, const std::string & value) {
+            params.kv_compact_ratio = std::stof(value);
+        }
+    ).set_examples({LLAMA_EXAMPLE_COMPLETION, LLAMA_EXAMPLE_CLI, LLAMA_EXAMPLE_SERVER})
+     .set_env("LLAMA_ARG_KV_COMPACT_RATIO"));
